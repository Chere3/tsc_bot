{
  "name": "tsc_bot",
  "module": "src/index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "dev": "bun run --watch --bun src/index.ts",
    "dev:debug": "bun run --watch --bun src/index.ts dev",
    "start": "bun run --bun src/index.ts start",
    "typecheck": "tsc --noEmit",
    "validate": "bun run typecheck"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "discord-api-types": "^0.37.101",
    "seyfert": "^2.1.0"
  }
}